// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  dateOfBirth DateTime  @map("date_of_birth")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  magicTokens         MagicToken[]
  friendshipsCreated  Friendship[] @relation("FriendshipFrom")
  friendshipsReceived Friendship[] @relation("FriendshipTo")

  @@map("users")
}

model MagicToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  expiresAt   DateTime  @map("expires_at")
  validatedAt DateTime? @map("validated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("magic_tokens")
}

model Friendship {
  id         String           @id @default(uuid())
  fromUserId String           @map("from_user_id")
  toUserId   String           @map("to_user_id")
  status     FriendshipStatus
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime?        @updatedAt @map("updated_at")

  fromUser User @relation("FriendshipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendshipTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("friendships")
}
