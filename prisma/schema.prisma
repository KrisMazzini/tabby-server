// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

enum GroupMemberStatus {
  pending
  accepted
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  dateOfBirth DateTime  @map("date_of_birth")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  magicTokens         MagicToken[]
  friendshipsCreated  Friendship[]  @relation("FriendshipFrom")
  friendshipsReceived Friendship[]  @relation("FriendshipTo")
  ownedGroups         Group[]       @relation("GroupOwner")
  groupMemberships    GroupMember[]
  paymentsSent        Payment[]     @relation("PaymentPayer")
  paymentsReceived    Payment[]     @relation("PaymentReceiver")

  @@map("users")
}

model MagicToken {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  expiresAt   DateTime  @map("expires_at")
  validatedAt DateTime? @map("validated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("magic_tokens")
}

model Friendship {
  id         String           @id @default(uuid())
  fromUserId String           @map("from_user_id")
  toUserId   String           @map("to_user_id")
  status     FriendshipStatus
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime?        @updatedAt @map("updated_at")

  fromUser User @relation("FriendshipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendshipTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("friendships")
}

model Group {
  id                 String    @id @default(uuid())
  name               String
  ownerId            String    @map("owner_id")
  defaultCurrencyIso String    @map("default_currency_iso")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  owner    User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members  GroupMember[]
  payments Payment[]

  @@index([ownerId])
  @@map("groups")
}

model GroupMember {
  groupId  String            @map("group_id")
  userId   String            @map("user_id")
  status   GroupMemberStatus
  joinedAt DateTime?         @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model Payment {
  id            String    @id @default(uuid())
  payerId       String    @map("payer_id")
  receiverId    String    @map("receiver_id")
  amountInCents Int       @map("amount_in_cents")
  currencyIso   String    @map("currency_iso")
  date          DateTime
  groupId       String?   @map("group_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  payer    User   @relation("PaymentPayer", fields: [payerId], references: [id], onDelete: Restrict)
  receiver User   @relation("PaymentReceiver", fields: [receiverId], references: [id], onDelete: Restrict)
  group    Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([payerId])
  @@index([receiverId])
  @@index([groupId])
  @@map("payments")
}
