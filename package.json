	"description": "",
	"type": "module",
	"main": "index.js",
	"scripts": {
		"dev": "tsx watch src/infra/server.ts",
		"start": "node dist/infra/server.cjs",
		"build": "tsup src --out-dir dist",
		"typecheck": "tsc --noEmit --skipLibCheck",
